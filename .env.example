# Use a dedicated, least-privilege CockroachDB user.
DATABASE_URL=postgresql://hindsight_app:change-me@cluster.example:26257/hindsight?sslmode=verify-full

# Keep schema ownership separate from the runtime application account.
MIGRATION_DATABASE_URL=postgresql://hindsight_migrator:change-me@cluster.example:26257/hindsight?sslmode=verify-full

# Optional: required only for the explicit Bedrock investigation proof.
# Credentials use the standard AWS SDK provider chain and do not belong here.
AWS_REGION=eu-central-1
BEDROCK_MODEL_ID=your-tool-capable-model-id

# Web replays stay deterministic unless each live integration is explicitly enabled.
HINDSIGHT_DEMO_BEDROCK=false
HINDSIGHT_DEMO_VECTOR=false
HINDSIGHT_DEMO_MCP=false

# Optional: enables the destructive, fixture-scoped POST /demo/reset endpoint.
# HINDSIGHT_DEMO_RESET_TOKEN=generate-a-long-random-value

# Optional: required only with --mcp. Keep this cluster-scoped service key in a secret store.
COCKROACH_MCP_CLUSTER_ID=00000000-0000-0000-0000-000000000000
COCKROACH_MCP_API_KEY=your-service-account-key

# Optional Titan V2 override for the explicit Distributed Vector Index proof.
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Optional web server binding. Use 0.0.0.0 only inside the deployment environment.
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
